# ─── Copy to .env and fill in your values ─────────────────────────────────────
# .env is gitignored. On Hugging Face Spaces, set these as Variables/Secrets
# under Space → Settings instead — pydantic-settings reads env vars directly.

# ─── LLM Provider ────────────────────────────────────────────────────────────
# "groq" (fast, cheap; works for both langgraph and autogen via OpenAI-compat)
# or "openai".
LLM_PROVIDER=groq

# ─── API Keys ────────────────────────────────────────────────────────────────
# Groq:   https://console.groq.com
# OpenAI: https://platform.openai.com/api-keys  (only if LLM_PROVIDER=openai)
# Tavily: https://app.tavily.com (free tier: 1000 searches/mo)
GROQ_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=

# ─── Models ──────────────────────────────────────────────────────────────────
# gpt-oss-120b is OpenAI's open-weights model on Groq, trained for the OpenAI
# tool-call format. Use it (not llama-3.3) so multi-tool agents don't emit
# malformed <function=name {...}> blobs that Groq's server rejects.
GROQ_MODEL=openai/gpt-oss-120b
OPENAI_MODEL=gpt-4o-mini

# ─── Agent loop bounds ───────────────────────────────────────────────────────
# Hard ceilings to keep cost predictable per request.
MAX_AGENT_ITERATIONS=8
CRITIC_MAX_REVISIONS=2

# ─── Tool tuning ─────────────────────────────────────────────────────────────
WEB_SEARCH_MAX_RESULTS=5
WEB_FETCH_TIMEOUT_S=15
WEB_FETCH_MAX_CHARS=8000

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
